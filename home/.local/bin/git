#!/usr/bin/env bash
# -----------------------------------------------------------------------
# git - wrapper around git that adds custom subcommands.
#
# Custom subcommands:
#   recent   - list remote branches sorted by most recent commit date
#   rewrite  - interactive rebase from divergence point of parent branch
#   compare  - open GitHub compare/PR view for current branch in browser
#   browse   - open GitHub tree view for current branch in browser
#   add      - proxy to forgit add when no paths given
# -----------------------------------------------------------------------

# Find the real git binary (skip this script itself)
_GIT=$(PATH=$(echo "$PATH" | tr ':' '\n' | grep -v "$(dirname "$0")" | tr '\n' ':') command -v git)

cmd="git-forgit"
if [ -n "$FORGIT" ]; then
    cmd="$FORGIT"
fi

case "$1" in
recent)
    $_GIT branch -r --sort=-committerdate --format="%(committerdate:relative)%09%(refname:short)"
    ;;
rewrite)
    base=$($_GIT log --oneline --decorate | fzf --prompt="rebase from> " | awk '{print $1}')
    [[ -z "$base" ]] && exit 0
    $_GIT rebase -i "${base}^"
    ;;
compare)
    branch=$($_GIT branch --show-current)
    url=$($_GIT config --get remote.origin.url | sed -Ee 's#(git@|git://)#https://#' -e 's@com:@com/@' -e 's/\.git$//')
    (xdg-open "$url/compare/$branch?expand=1" &>/dev/null &)
    ;;
browse)
    branch=$($_GIT branch --show-current)
    url=$($_GIT config --get remote.origin.url | sed -Ee 's#(git@|git://)#https://#' -e 's@com:@com/@' -e 's/\.git$//')
    (xdg-open "$url/tree/$branch" &>/dev/null &)
    ;;
add)
    if [ $# -eq 1 ]; then
        $cmd add
    else
        shift
        $_GIT add "$@"
    fi
    ;;
*)
    $_GIT "$@"
    ;;
esac
