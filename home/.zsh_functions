# Print text in yellow bold.
yellow_bold() { printf "\e[1;33m%b\e[0m" "$*"; }

# Prompt the user for confirmation before proceeding.
# Usage: confirm [message]
# Returns 0 if confirmed, 1 otherwise.
confirm() {
    local msg="${1:-Proceed?}"
    read -r "ans?$msg [y/N] "
    [[ "$ans" == "y" || "$ans" == "Y" ]]
}

# Prompt for a secret value without echoing input.
# Usage: ask_secret <prompt>
# Prints the entered value to stdout.
ask_secret() {
    local prompt="$1"
    local input confirm

    read -s "input?$(yellow_bold '[INPUT]'): $prompt " >&2
    echo >&2

    echo "$input"
}

# Print a warning message to stderr.
warn()    { printf "⚠️ WARN: %s\n"    "$*" >&2; }

# Print an error message to stderr.
error()   { printf "❌ ERROR: %s\n"   "$*" >&2; }

# Export an environment variable without saving it to shell history.
# Usage: putenv VAR VALUE
putenv() {
    if [[ -z "$1" || -z "$2" ]]; then
        echo "Usage: putenv VAR VALUE" >&2
        return 1
    fi
    fc -p /dev/null 0 0
    export "$1=$2"
    fc -P
}

# Link a local Composer package into the current project via a path repository.
# Usage: composer-link <package_path>
composer-link() {
    local package_path="$1"

    if [[ -z "$package_path" ]]; then
        echo "Usage: composer-link <package_path>"
        return 1
    fi

    if [[ ! -f "$package_path/composer.json" ]]; then
        echo "Error: composer.json not found in $package_path"
        return 1
    fi

    local name
    name=$(jq -r '.name' "$package_path/composer.json")

    if [[ "$name" == "null" || -z "$name" ]]; then
        echo "Error: Invalid or missing package name in composer.json"
        return 1
    fi

    composer config repositories.local '{"type": "path", "url": "'"$package_path"'"}' --file composer.json
    composer require "$name" @dev
}

# Link a local npm package into the current project.
# Usage: npm-link <package_path>
npm-link() {
    local package_path="$1"

    if [[ -z "$package_path" ]]; then
        echo "Usage: npm-link <package_path>"
        return 1
    fi

    if [[ ! -f "$package_path/package.json" ]]; then
        echo "Error: package.json not found in $package_path"
        return 1
    fi

    local package_name
    package_name=$(node -p "require('$package_path/package.json').name" 2>/dev/null)

    if [[ -z "$package_name" || "$package_name" == "undefined" ]]; then
        echo "Error: Invalid or missing package name in package.json"
        return 1
    fi

    echo "Linking $package_name at $package_path"
    cd "$package_path" || return 1
    npm link

    cd - >/dev/null || return 1
    npm link "$package_name"
}

# Run the ~/shutdown script if it exists, then shut down the system.
bye(){
    if [ -f "$HOME/shutdown" ]; then
        source "$HOME/shutdown"
    fi
    shutdown now
}

# Create a Python virtual environment in .venv using copies (not symlinks).
virtualenv_make(){
    python -m venv .venv --copies
}


# Switch kubectl namespace interactively via fzf.
kns() {
    local ns
    ns=$(kubectl get namespaces --no-headers -o custom-columns=':metadata.name' | fzf --prompt='namespace> ')
    [[ -n "$ns" ]] && kubectl config set-context --current --namespace="$ns" && echo "Switched to namespace: $ns"
}

# Switch kubectl context interactively via fzf.
kctx() {
    local ctx
    ctx=$(kubectl config get-contexts --no-headers -o name | fzf --prompt='context> ')
    [[ -n "$ctx" ]] && kubectl config use-context "$ctx"
}

# Create a kind cluster and install metrics-server with --kubelet-insecure-tls.
# Usage: kind-create [name]
kind-create() {
    local name="${1:-kind}"
    shift

    kind create cluster --name "$name" "$@" || return 1

    echo "=> patching CoreDNS to use real upstream DNS (avoids systemd-resolved 127.0.0.53 leaking in)"
    kubectl get configmap coredns -n kube-system -o json \
        | sed 's|forward \. /etc/resolv.conf|forward . 8.8.8.8 1.1.1.1|' \
        | kubectl apply -f - || return 1
    kubectl rollout restart deployment/coredns -n kube-system || return 1
    kubectl rollout status deployment/coredns -n kube-system || return 1

    echo "=> installing metrics-server"
    kubectl apply -f https://github.com/kubernetes-sigs/metrics-server/releases/latest/download/components.yaml || return 1

    echo "=> patching metrics-server for kind (--kubelet-insecure-tls)"
    kubectl patch deployment metrics-server -n kube-system --type=json \
        -p='[{"op":"add","path":"/spec/template/spec/containers/0/args/-","value":"--kubelet-insecure-tls"}]' || return 1

    echo "=> done, cluster: $name"
}

# Open a nix-shell with a package at a specific version by searching nixpkgs commits.
# Usage: nix-pkg-shell <package> [--version <version>]
nix-pkg-shell() {
    local pkg version commit

    pkg="$1"
    if [[ -z "$pkg" ]]; then
        echo "Usage: nix-pkg-shell <package> [--version <version>]" >&2
        return 1
    fi
    shift

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --version) version="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; return 1 ;;
        esac
    done

    if [[ -n "$version" ]]; then
        commit=$(curl -fsSL \
            "https://api.github.com/search/commits?q=${pkg}+${version}+repo:NixOS/nixpkgs&per_page=5" \
            -H "Accept: application/vnd.github.cloak-preview+json" 2>/dev/null \
            | jq -r --arg pkg "$pkg" --arg ver "$version" '
                .items[]
                | select(.commit.message | test($pkg + ":.*-> " + $ver + "($|[^0-9])"; "i"))
                | .sha
            ' | head -1)

        if [[ -z "$commit" ]]; then
            echo "Error: no nixpkgs commit found for ${pkg} version ${version}" >&2
            return 1
        fi
    else
        commit=$(curl -fsSL "https://channels.nixos.org/nixpkgs-unstable/git-revision" 2>/dev/null)
        if [[ -z "$commit" ]]; then
            echo "Error: failed to fetch latest nixpkgs-unstable commit" >&2
            return 1
        fi
    fi

    echo "=> nix-shell with ${pkg}${version:+ @ ${version}} (commit: ${commit})"
    IN_NIX_SHELL=1 NIX_PKG="${pkg}${version:+@${version}}" nix shell "github:NixOS/nixpkgs/${commit}#${pkg}"
}

# Delete GitHub Actions runs for a workflow on a branch, with fzf workflow selection.
# Usage: gh-delete-runs [branch]  (defaults to current git branch)
gh-delete-runs() {
  local branch workflow wf candidates

  branch="${1:-$(git branch --show-current)}"

  echo "Loading workflows for branch: $branch ..."

  candidates="$(
    gh workflow list --json name -q '.[].name' |
      while IFS= read -r wf; do
        if gh run list \
          --workflow "$wf" \
          --branch "$branch" \
          --limit 1 \
          --json databaseId \
          -q 'length > 0' | grep -q true; then
          printf '%s\n' "$wf"
        fi
      done
  )"
  printf "\033[1A\033[K"
  if [[ -z "$candidates" ]]; then
    echo "No workflows with runs found for branch: $branch"
    return 1
  fi

  workflow=$(
    printf '%s\n' "$candidates" |
      fzf --prompt="Workflow [$branch]: "
  )

  [[ -z "$workflow" ]] && return 1

  echo "About to delete runs for workflow '$workflow' on branch '$branch'"

  printf "Continue? [y/N] "
  read confirm
  [[ "$confirm" =~ ^[Yy]$ ]] || {
    echo "Cancelled"
    return 1
  }

  gh run list \
    --branch "$branch" \
    --workflow "$workflow" \
    --limit 1000 \
    --json databaseId \
    -q '.[].databaseId' |
    xargs -r -n1 gh run delete
}
