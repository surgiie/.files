#!/usr/bin/env bash
# pipe json strings through jq, while allowing non-json lines to pass through unchanged
jq -Rr --indent 2 '
  . as $line |
  ($line | index("{")) as $i |
  if $i == null then $line
  elif $i > 0 then ($line[:$i] | rtrimstr(" ")), (try ($line[$i:] | fromjson) catch empty)
  else (try ($line | fromjson) catch empty)
  end
'
