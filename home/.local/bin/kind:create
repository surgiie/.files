#!/usr/bin/env bash
# kind:create — create a kind cluster with clean DNS and metrics-server configured
#
# USAGE:
#   kind:create [--name NAME] [-- KIND_FLAGS...]
#
# FLAGS:
#   --name NAME   Cluster name (default: kind)
#   --            Pass remaining args to `kind create cluster`

set -euo pipefail

name="kind"
extra_args=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --name) shift; name="$1" ;;
        --) shift; extra_args+=("$@"); break ;;
        *) echo "Unknown flag: $1. Try --help." >&2; exit 1 ;;
    esac
    shift
done

config=$(mktemp /tmp/kind-config-XXXXXX.yaml)
trap 'rm -f "$config"' EXIT

cat > "$config" <<'EOF'
kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
networking:
  dnsSearch: []
kubeadmConfigPatches:
  - |
    kind: ClusterConfiguration
    dns:
      imageRepository: registry.k8s.io
  - |
    kind: KubeletConfiguration
    clusterDNS:
      - 10.96.0.10
EOF

echo "=> creating kind cluster: $name"
kind create cluster --name "$name" --config "$config" "${extra_args[@]+"${extra_args[@]}"}"

echo "=> patching CoreDNS to forward to public DNS"
kubectl get configmap coredns -n kube-system -o json | python3 -c "
import json, sys
cm = json.load(sys.stdin)
cm['data']['Corefile'] = '''.:53 {
    errors
    health {
       lameduck 5s
    }
    ready
    kubernetes cluster.local in-addr.arpa ip6.arpa {
       pods insecure
       fallthrough in-addr.arpa ip6.arpa
       ttl 30
    }
    prometheus :9153
    forward . 8.8.8.8 1.1.1.1 {
       max_concurrent 1000
    }
    cache 30 {
       disable success cluster.local
       disable denial cluster.local
    }
    loop
    reload
    loadbalance
}
'''
print(json.dumps(cm))
" | kubectl apply -f -
kubectl rollout restart deployment/coredns -n kube-system
kubectl rollout status deployment/coredns -n kube-system

echo "=> installing metrics-server"
kubectl apply -f https://github.com/kubernetes-sigs/metrics-server/releases/latest/download/components.yaml

echo "=> patching metrics-server for kind (--kubelet-insecure-tls)"
kubectl patch deployment metrics-server -n kube-system --type=json \
    -p='[{"op":"add","path":"/spec/template/spec/containers/0/args/-","value":"--kubelet-insecure-tls"}]'

echo "=> done, cluster: $name"
